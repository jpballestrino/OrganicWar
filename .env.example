PORT=3000

# REQUIRED in production — must be a long random string (e.g. openssl rand -hex 64).
# If unset in production the server will refuse to start.
JWT_SECRET=dev_jwt_secret_key_change_me_in_production
SESSION_SECRET=dev_session_secret_key_change_me_in_production

# Max simultaneous rooms. Each room is a worker thread with a full WASM instance (~80-120 MB RSS).
# On a 1 GB VPS: 8 rooms. On 2 GB: 12-15. On 4 GB: 25-30.
# Monitor actual usage via GET /healthz (returns totalWorkerRssMB + per-room breakdown).
MAX_CONCURRENT_ROOMS=20

# Max simultaneous WebSocket connections from a single IP (prevents slot-farming / ELO abuse).
# Localhost connections are always exempt so dev tools aren't blocked.
MAX_CONNECTIONS_PER_IP=5

# Simulation tick rate (Hz). Higher = smoother conquest but more CPU. 25 is the default.
SIM_TICK_HZ=25

# Set to 1 to log per-room tick/snapshot profiling every 5 seconds (dev/perf tuning only).
SIM_PROFILE=0

# SSL — set to file paths for Node-level TLS termination.
# In production, prefer Caddy or Nginx as the reverse proxy (see Caddyfile).
# SSL_CERT=/etc/ssl/certs/your-cert.pem
# SSL_KEY=/etc/ssl/private/your-key.pem

# Public URL of your deployed server (no trailing slash).
# Used to build links in emails (password reset, email verification).
# In production on Render, set this to e.g. https://organicwar.onrender.com
APP_URL=http://localhost:3000

# Node Mailer config (for password reset and email verification)
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# OAuth login client details (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
CORS_ORIGIN=*
